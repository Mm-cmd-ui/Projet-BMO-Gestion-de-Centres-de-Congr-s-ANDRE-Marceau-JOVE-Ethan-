            "0a02c1d7-9498-4351-a620-49f5e8b481fd": {
              "id": "0a02c1d7-9498-4351-a620-49f5e8b481fd",
              "name": "+ consulterStats(periode_nom)",
              "type": "ClassMethod",
              "owner": "b7d9009d-53ad-4862-a574-4ee92973d7ca",
              "bounds": {
                "x": -619.5,
                "y": -139.5,
                "width": 419,
                "height": 30
              },
              "code": "def consulterStats(self, periode_nom):\n    # On tente de récupérer la liste des réservations par différents noms\n    # 1. 'reservations' (minuscule)\n    # 2. 'Reservations' (majuscule)\n    # 3. 'ses_reservations' (nom de rôle courant)\n    resas = getattr(self, 'reservations', getattr(self, 'Reservations', []))\n    \n    if not resas:\n        # Message d'aide spécifique pour ne pas paniquer en démo\n        return [f\"Période: {periode_nom}\", \"Info: Reliez les réservations au Gestionnaire dans l'IHM.\"]\n    \n    # Affichage propre des résultats\n    stats = []\n    for r in resas:\n        nom = getattr(r, 'nom', 'Resa')\n        prix = getattr(r, 'prix', getattr(r, 'Prix', 0))\n        stats.append(f\"{nom} | {prix}€\")\n        \n    return stats",
              "visibility": "public",
              "attributeType": "str",
              "implementationType": "code",
              "stateMachineId": "",
              "quantumCircuitId": "",
              "isOptional": false
            },
