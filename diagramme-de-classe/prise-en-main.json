            "52e28cd2-9cb5-47bb-91dd-a0a631e7a8b2": {
              "id": "52e28cd2-9cb5-47bb-91dd-a0a631e7a8b2",
              "name": "+ verifierCapacite(nb_a_tester)",
              "type": "ClassMethod",
              "owner": "b5314042-caae-4bd9-b12a-bbd5b0103721",
              "bounds": {
                "x": -389.5,
                "y": 230.5,
                "width": 389,
                "height": 30
              },
              "code": "def verifierCapacite(self, nb_a_tester):\n    try:\n        # On teste les 3 variantes de noms les plus courantes\n        v1 = getattr(self, 'Capacite', None)\n        v2 = getattr(self, 'capacite', None)\n        v3 = getattr(self, 'capaciteMax', None)\n        \n        # On prend la première qui n'est pas vide\n        limite = 0\n        for v in [v1, v2, v3]:\n            if v is not None:\n                limite = int(v)\n                break\n        \n        saisie = int(nb_a_tester)\n        \n        if saisie <= limite:\n            return f\"Disponible : {saisie} <= {limite}\"\n        else:\n            return f\"Capacité dépassée : {saisie} > {limite}\"\n    except:\n        return \"Erreur de saisie\"",
              "visibility": "public",
              "attributeType": "str",
              "implementationType": "code",
              "stateMachineId": "",
              "quantumCircuitId": "",
              "isOptional": false
            }
